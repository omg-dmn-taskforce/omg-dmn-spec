{
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "xml.catalogs": [
        "catalog.xml"
    ],
    "xml.downloadExternalResources.enabled": false,
    "xml.validation.schema.enabled": "always",
    "xml.validation.namespaces.enabled": "always",
    "xml.validation.disallowDocTypeDecl": true,
    "xml.format.splitAttributes": "preserve",
    "xml.format.xsiSchemaLocationSplit": "none",
    "xml.format.preserveAttributeLineBreaks": true,
    "xml.format.preservedNewlines": 2,
    "xml.format.spaceBeforeEmptyCloseTag": true,
    "xml.format.enforceQuoteStyle": "preferred",
    "xml.format.emptyElements": "collapse",
    "xml.preferences.quoteStyle": "double",
    "xml.codeLens.enabled": true,
    "xml.symbols.showReferencedGrammars": true,
    "xml.fileAssociations": [
        {
            "pattern": "**/*.dmn",
            "systemId": "xsd/DMN.xsd"
        }
    ],
    "xml.filePathSupport.mappings": [
        // see: https://github.com/redhat-developer/vscode-xml/blob/main/docs/Features/XMLFilePathSupport.md
        {
            "pattern": "**/*.dmn",
            "expressions": [
               {
                  "xpath": "import/@locationURI"
               }
            ]
        }
    ],
    "xml.references": [
        // see: https://github.com/redhat-developer/vscode-xml/blob/main/docs/Features/XMLReferencesFeatures.md
        {
            "pattern": "**/*.dmn",
            "expressions": [
                {
                    "from": "itemComponent/typeRef/text()",
                    "to": "itemDefinition/@name"
                },
                {
                    "from": "@dmnElementRef",
                    "to": "@id"
                },
                {
                    "from": "@href",
                    "prefix": "#",
                    "to": "@id"
                },
                {
                    "from": "DMNEdge/@sourceElement",
                    "to": "DMNShape/@id"
                },
                {
                    "from": "DMNEdge/@targetElement",
                    "to": "DMNShape/@id"
                }
            ]
        },
        {
            "pattern": "**/*.xmi",
            "expressions": [
                {
                    "from": "@idref",
                    "to": "@id"
                },
                {
                    "from": "@type",
                    "to": "@id"
                },
                {
                    "from": "@element",
                    "to": "@id"
                }
            ]
        }
    ]
}