<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions dmnVersion="1.7" id="dish-decisions" name="Dish Decisions"
  namespace="http://www.omg.org/spec/DMN/20180521/dish-example/"
  xmlns:dmn="https://www.omg.org/spec/DMN/"
  xmlns:dmndi="https://www.omg.org/spec/DMN/DMNDI/"
  xmlns:di="https://www.omg.org/spec/SCE/DI/"
  xmlns:dc="https://www.omg.org/spec/SCE/DC/"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
    https://www.omg.org/spec/DMN/
    https://www.omg.org/spec/DMN/DMN.xsd
    https://www.omg.org/spec/DMN/DMNDI/
    https://www.omg.org/spec/DMN/DMNDI.xsd
    https://www.omg.org/spec/SCE/DI/
    https://www.omg.org/spec/SCE/DI.xsd
    https://www.omg.org/spec/SCE/DC/
    https://www.omg.org/spec/SCE/DC.xsd
  ">

  <dmn:inputData name="Type of day" id="dayType_id">
    <dmn:variable typeRef="string" name="Type of day" id="dayType_ii" />
  </dmn:inputData>
  <dmn:inputData name="Weather in Celsius" id="temperature_id">
    <dmn:variable typeRef="integer" name="Weather in Celsius" id="temperature_ii" />
  </dmn:inputData>
  <dmn:knowledgeSource name="Host" id="host_ks" />
  <dmn:decision id="dish" name="Dish">
    <dmn:informationRequirement id="season_ir">
      <dmn:requiredDecision href="#season" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="guestCount_ir">
      <dmn:requiredDecision href="#guestCount" />
    </dmn:informationRequirement>
    <dmn:authorityRequirement id="host_ar">
      <dmn:requiredAuthority href="#host_ks" />
    </dmn:authorityRequirement>
    <dmn:decisionTable id="dishDecisionTable">
      <dmn:input id="seasonInput" label="Season">
        <dmn:inputExpression id="seasonInputExpression" typeRef="string">
          <dmn:text>season</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:input id="guestCountInput" label="How many guests">
        <dmn:inputExpression id="guestCountInputExpression" typeRef="integer">
          <dmn:text>guestCount</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="output1" label="Dish" name="desiredDish" typeRef="string" />
      <dmn:rule id="row-495762709-1">
        <dmn:inputEntry id="UnaryTests_1nxcsjr">
          <dmn:text><![CDATA["Winter"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="UnaryTests_1r9yorj">
          <dmn:text><![CDATA[<=8]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_1mtwzqz">
          <dmn:text><![CDATA["Spareribs"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-495762709-2">
        <dmn:inputEntry id="UnaryTests_1lxjbif">
          <dmn:text><![CDATA["Winter"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="UnaryTests_0nhiedb">
          <dmn:text><![CDATA[>8]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_1h30r12">
          <dmn:text><![CDATA["Pasta"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-495762709-3">
        <dmn:inputEntry id="UnaryTests_0ifgmfm">
          <dmn:text><![CDATA["Summer"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="UnaryTests_12cib9m">
          <dmn:text><![CDATA[>10]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_0wgaegy">
          <dmn:text><![CDATA["Light salad"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-495762709-7">
        <dmn:inputEntry id="UnaryTests_0ozm9s7">
          <dmn:text><![CDATA["Summer"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="UnaryTests_0sesgov">
          <dmn:text><![CDATA[<=10]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_1dvc5x3">
          <dmn:text><![CDATA["Beans salad"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-445981423-3">
        <dmn:inputEntry id="UnaryTests_1er0je1">
          <dmn:text><![CDATA["Spring"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="UnaryTests_1uzqner">
          <dmn:text><![CDATA[<10]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_1pxy4g1">
          <dmn:text><![CDATA["Stew"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-445981423-4">
        <dmn:inputEntry id="UnaryTests_06or48g">
          <dmn:text><![CDATA["Spring"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="UnaryTests_0wa71sy">
          <dmn:text><![CDATA[>=10]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_09ggol9">
          <dmn:text><![CDATA["Steak"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>
  <dmn:decision id="season" name="Season">
    <dmn:informationRequirement id="temperature_ir">
      <dmn:requiredInput href="#temperature_id" />
    </dmn:informationRequirement>
    <dmn:decisionTable id="seasonDecisionTable">
      <dmn:input id="temperatureInput" label="Weather in Celsius">
        <dmn:inputExpression id="temperatureInputExpression" typeRef="integer">
          <dmn:text>temperature</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="seasonOutput" label="season" name="season" typeRef="string" />
      <dmn:rule id="row-495762709-5">
        <dmn:inputEntry id="UnaryTests_1fd0eqo">
          <dmn:text><![CDATA[>30]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_0l98klb">
          <dmn:text><![CDATA["Summer"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-495762709-6">
        <dmn:inputEntry id="UnaryTests_1nz6at2">
          <dmn:text><![CDATA[<10]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_08moy1k">
          <dmn:text><![CDATA["Winter"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-445981423-2">
        <dmn:inputEntry id="UnaryTests_1a0imxy">
          <dmn:text>[10..30]</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_1poftw4">
          <dmn:text><![CDATA["Spring"]]></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>
  <dmn:decision id="guestCount" name="Guest Count">
    <dmn:informationRequirement id="dayType_ir">
      <dmn:requiredInput href="#dayType_id" />
    </dmn:informationRequirement>
    <dmn:decisionTable id="guestCountDecisionTable">
      <dmn:input id="typeOfDayInput" label="Type of day">
        <dmn:inputExpression id="typeOfDayInputExpression" typeRef="string">
          <dmn:text>dayType</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="guestCountOutput" label="Guest count" name="guestCount" typeRef="integer" />
      <dmn:rule id="row-495762709-8">
        <dmn:inputEntry id="UnaryTests_0l72u8n">
          <dmn:text><![CDATA["Weekday"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_0wuwqaz">
          <dmn:text>4</dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-495762709-9">
        <dmn:inputEntry id="UnaryTests_03a73o9">
          <dmn:text><![CDATA["Holiday"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_1whn119">
          <dmn:text>10</dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="row-495762709-10">
        <dmn:inputEntry id="UnaryTests_12tygwt">
          <dmn:text><![CDATA["Weekend"]]></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_1b5k9t8">
          <dmn:text>15</dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="_di1">
      <dmndi:DMNShape id="_di2" dmnElementRef="dish">
        <dc:Bounds x="150" y="10" width="100" height="55" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_di3" dmnElementRef="season">
        <dc:Bounds x="10" y="140" width="140" height="55" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_di4" dmnElementRef="guestCount">
        <dc:Bounds x="230" y="140" width="210" height="55" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_di5" dmnElementRef="temperature_id">
        <dc:Bounds x="5" y="270" width="170" height="90" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_di6" dmnElementRef="dayType_id">
        <dc:Bounds x="240" y="270" width="200" height="60" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_di7" dmnElementRef="host_ks">
        <dc:Bounds x="495" y="10" width="120" height="75" />
      </dmndi:DMNShape>
      <dmndi:DMNEdge id="_di8" dmnElementRef="season_ir">
        <di:waypoint x="80" y="140" />
        <di:waypoint x="205" y="65" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="_di9" dmnElementRef="guestCount_ir">
        <di:waypoint x="345" y="140" />
        <di:waypoint x="205" y="65" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="_di10" dmnElementRef="temperature_ir">
        <di:waypoint x="80" y="270" />
        <di:waypoint x="80" y="195" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="_di11" dmnElementRef="dayType_ir">
        <di:waypoint x="340" y="270" />
        <di:waypoint x="340" y="195" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="_di12" dmnElementRef="host_ar">
        <di:waypoint x="495" y="30" />
        <di:waypoint x="250" y="30" />
      </dmndi:DMNEdge>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</dmn:definitions>
