<?xml version="1.0" encoding="UTF-8"?>
<!--
    OASIS XML Catalog mapping DMN namespace URIs to their publicly hosted XSD files.

    Usage: point your XML tool's catalog setting at this file so it can resolve
    DMN namespace URIs to the correct schema for validation and code completion,
    without needing to specify a schemaLocation in each document.

    Examples:
      VS Code (vscode-xml):  "xml.catalogs": ["path/to/catalog.xml"]
      xmllint:               XML_CATALOG_FILES=path/to/catalog.xml xmllint - -schema ...
      oXygen XML Editor:     Options > Preferences > XML > XML Catalogs
-->
<catalog xmlns="urn:oasis:names:tc:entity:xmlns:xml:catalog">

    <!-- DMN 1.7+ (version-free namespace) -->
    <uri
        name="https://www.omg.org/spec/DMN/"
        uri="https://www.omg.org/spec/DMN/DMN.xsd" />
    <uri
        name="https://www.omg.org/spec/DMN/DMNDI/"
        uri="https://www.omg.org/spec/DMN/DMNDI.xsd" />
    <uri
        name="https://www.omg.org/spec/SCE/DI/"
        uri="https://www.omg.org/spec/SCE/DI.xsd" />
    <uri
        name="https://www.omg.org/spec/SCE/DC/"
        uri="https://www.omg.org/spec/SCE/DC.xsd" />

    <!-- DMN 1.6 (20240513) -->
    <uri
        name="https://www.omg.org/spec/DMN/20240513/MODEL/"
        uri="https://www.omg.org/spec/DMN/20240513/DMN16.xsd" />

    <!-- DMN 1.5 (20230324) -->
    <uri
        name="https://www.omg.org/spec/DMN/20230324/MODEL/"
        uri="https://www.omg.org/spec/DMN/20230324/DMN15.xsd" />
    <uri
        name="https://www.omg.org/spec/DMN/20230324/DMNDI/"
        uri="https://www.omg.org/spec/DMN/20230324/DMNDI15.xsd" />

    <!-- DMN 1.4 (20211108) -->
    <uri
        name="https://www.omg.org/spec/DMN/20211108/MODEL/"
        uri="https://www.omg.org/spec/DMN/20211108/DMN14.xsd" />

    <!-- DMN 1.3 (20191111) -->
    <uri
        name="https://www.omg.org/spec/DMN/20191111/MODEL/"
        uri="https://www.omg.org/spec/DMN/20191111/DMN13.xsd" />
    <uri
        name="https://www.omg.org/spec/DMN/20191111/DMNDI/"
        uri="https://www.omg.org/spec/DMN/20191111/DMNDI13.xsd" />

    <!-- DMN 1.2 (20180521) — XSD files published at 20180505 -->
    <uri
        name="http://www.omg.org/spec/DMN/20180521/MODEL/"
        uri="https://www.omg.org/spec/DMN/20180505/DMN12.xsd" />
    <uri
        name="http://www.omg.org/spec/DMN/20180521/DMNDI/"
        uri="https://www.omg.org/spec/DMN/20180505/DMNDI12.xsd" />
    <uri
        name="http://www.omg.org/spec/DMN/20180521/DI/"
        uri="https://www.omg.org/spec/DMN/20180505/DI.xsd" />
    <uri
        name="http://www.omg.org/spec/DMN/20180521/DC/"
        uri="https://www.omg.org/spec/DMN/20180505/DC.xsd" />

    <!-- DMN 1.1 (20151101) — namespace URI is the XSD URL itself -->
    <uri
        name="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
        uri="http://www.omg.org/spec/DMN/20151101/dmn.xsd" />

    <!-- DMN 1.0 (20130901) -->
    <uri
        name="http://www.omg.org/spec/DMN/20130901"
        uri="https://www.omg.org/spec/DMN/20141115/dmn.xsd" />
    <uri
        name="http://www.omg.org/spec/FEEL/20140401"
        uri="https://www.omg.org/spec/DMN/20141115/dmn3.xsd" />

</catalog>
